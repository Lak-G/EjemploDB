@page
@model EjemploDB.Pages.Productos.CreateModel
@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="form-container">
    <h2>Nuevo Producto</h2>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="Producto.Nombre">Nombre</label>
            <input asp-for="Producto.Nombre" class="form-input" placeholder="Nombre del producto" />
            <span asp-validation-for="Producto.Nombre" class="validation-msg"></span>
        </div>
        <div class="form-group">
            <label asp-for="Producto.Precio">Precio</label>
            <input asp-for="Producto.Precio" class="form-input" type="number" step="0.01" placeholder="0.00" />
            <span asp-validation-for="Producto.Precio" class="validation-msg"></span>
        </div>
        <div class="form-group">
            <label asp-for="Producto.Cantidad">Cantidad</label>
            <input asp-for="Producto.Cantidad" class="form-input" type="number" placeholder="0" />
            <span asp-validation-for="Producto.Cantidad" class="validation-msg"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-action">Guardar</button>
            <a asp-page="Index" class="btn-cancel">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
